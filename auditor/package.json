    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clickhouse/client": "^1.20.0",
    "@composio/core": "^0.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
