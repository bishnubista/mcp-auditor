# =============================================================================
# MCP Server Auditor — environment template
# Copy to `.env` (Bun auto-loads it from this dir): cp .env.example .env
# Then paste real values. NEVER commit .env (it is gitignored).
# Posture: REAL APIs by default. A missing key makes that integration FAIL LOUD
# (nonzero exit) rather than silently mocking. Offline/demo modes are explicit opt-ins.
# =============================================================================

# -----------------------------------------------------------------------------
# Composio  — files the audit report as a REAL GitHub issue
# Required for live `bun run file-report`. Without COMPOSIO_API_KEY it degrades to
# writing out/composio-payload.json (demo:local uses that degraded path on purpose).
# COMPOSIO_GITHUB_REPO accepts owner/name OR a full https://github.com/owner/name URL.
# Safety rail: live filing is allowlisted to a repo NAMED "mcp-audit-reports";
# any other repo name degrades to the preview payload (defaults to bishnubista/mcp-audit-reports).
# -----------------------------------------------------------------------------
COMPOSIO_API_KEY=
COMPOSIO_GITHUB_REPO=owner/mcp-audit-reports   # repo to open the issue in (REQUIRED for live)
COMPOSIO_USER_ID=default                 # Composio user/entity id
COMPOSIO_CONNECTED_ACCOUNT_ID=           # optional: explicit connected GitHub account id
# COMPOSIO_PAYLOAD_PATH=                  # optional: override path for the degraded payload artifact

# -----------------------------------------------------------------------------
# cited.md / Senso.ai  — publishes the cited audit to the open web
# Real endpoint: https://sdk.senso.ai/api/v1/content/raw  (auth: X-API-Key)
# Required for live `bun run publish:cited`. Without the key it EXITS NONZERO
# unless you pass --offline / set CITED_OFFLINE=1 (writes out/cited.md only).
# -----------------------------------------------------------------------------
CITED_API_KEY=                           # Senso org key (tgr_live_... / tgr_test_...)
# CITED_API_URL=https://sdk.senso.ai/api/v1   # override base url if needed
# CITED_HANDLE=                           # your cited.md handle (for the published URL)
# CITED_OFFLINE=                          # set to 1 to render out/cited.md locally (opt-in only)

# -----------------------------------------------------------------------------
# x402 payment rail  — monetizes the audit (`bun run serve:x402`)
# Real onchain settlement via a facilitator. Without a facilitator + X402_DEMO_ACCEPT
# unset, a demo payment header is REJECTED (402) — no free reports.
# -----------------------------------------------------------------------------
PAY_TO_ADDRESS=                          # your receiving wallet address (REQUIRED for live)
X402_FACILITATOR_URL=https://x402.org/facilitator   # facilitator that /verify + /settle
X402_NETWORK=base-sepolia                # network (testnet default)
X402_PRICE=$0.10                         # price per audit
# X402_DEMO_ACCEPT=                       # set to 1 ONLY for offline stage demo (accepts X-PAYMENT: demo)

# -----------------------------------------------------------------------------
# ClickHouse  — live findings store + severity dashboard (`bun run dashboard`)
# Without CLICKHOUSE_URL reachable, dashboard renders an in-memory rollup instead.
# -----------------------------------------------------------------------------
CLICKHOUSE_URL=                          # e.g. https://<id>.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# -----------------------------------------------------------------------------
# Guild AI ("Harness")  — agent-governance audit sink
# NOTE: no public Guild SDK/API exists on npm. These wire an ASSUMED REST contract
# (POST {GUILD_API_URL}/audit, Bearer key). The real working governance proof is the
# local audit.jsonl trail. Swap the 2 constants if Guild provides real docs at the venue.
# -----------------------------------------------------------------------------
GUILD_API_KEY=
GUILD_API_URL=https://api.guild.ai/v1
GUILD_PROJECT_ID=

# -----------------------------------------------------------------------------
# Render (deploy the seeded target server to a public URL)
# Used by the Render CLI/Blueprint, not read by app code. See target-server/DEPLOY.md.
# -----------------------------------------------------------------------------
RENDER_API_KEY=

# -----------------------------------------------------------------------------
# Local / test knobs (leave unset for normal runs)
# -----------------------------------------------------------------------------
# PORT=                                   # http target / x402 server port
# DEMO_TARGET_CMD=                        # override target server command (demo:local negative test)
# FINDINGS_PATH= / AUDIT_PATH= / REPORT_PATH=   # artifact path overrides (synthesizer/test)
