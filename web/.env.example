# MCP Auditor Web — environment

# Render streaming backend origin (POST /audits + GET /audits/:id/events).
# Leave UNSET for `bun run dev` to default into the built-in MOCK SSE stream.
NEXT_PUBLIC_AUDIT_BACKEND_URL=

# Force the built-in mock stream even when a backend URL is set (demo / offline).
# "1" = always mock. Unset/"0" = use backend when NEXT_PUBLIC_AUDIT_BACKEND_URL is present.
NEXT_PUBLIC_MOCK=
